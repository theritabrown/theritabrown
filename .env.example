VITE_SUPABASE_URL=
# Preferred current Supabase browser key name.
VITE_SUPABASE_PUBLISHABLE_KEY=
# Also supported if your dashboard labels it anon/public.
VITE_SUPABASE_ANON_KEY=

# Server-only. Never expose this in frontend code or Cloudflare Pages public vars.
# Used by npm run create-admin and the Cloudflare keep-alive Worker.
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAIL=
ADMIN_TEMP_PASSWORD=

# Optional server-only key for stronger product imports from stores that block metadata scraping.
# This is required for reliable Shein image import because Shein serves bot-challenge pages to Cloudflare.
# Either name is supported; SHEIN_SEARCH_API_KEY takes priority.
SHEIN_SEARCH_API_KEY=
SEARCHAPI_API_KEY=
